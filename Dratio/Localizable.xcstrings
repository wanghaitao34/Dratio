{
  "sourceLanguage" : "zh-Hans",
  "strings" : {
    "" : {

    },
    "Dratio" : {

    },
    "help.close" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Got it"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "知道了"
          }
        }
      }
    },
    "help.step1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click the window you want to resize to make it active"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击你要调整的窗口，使其成为当前窗口"
          }
        }
      }
    },
    "help.step2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click the Dratio icon in the menu bar, pick a ratio"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击菜单栏的 Dratio 图标，选择目标比例"
          }
        }
      }
    },
    "help.step3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Or use global shortcuts (e.g. ⌥⌘1 = 16:9)"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "或直接使用全局快捷键 (如 ⌥⌘1 = 16:9)"
          }
        }
      }
    },
    "help.tip.maximize" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥⌘M Maximize window to fit screen at current ratio"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥⌘M 将窗口以当前比例最大化适配屏幕"
          }
        }
      }
    },
    "help.tip.scale" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥⌘= Zoom In / ⌥⌘- Zoom Out (keeps ratio)"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥⌘= 放大 / ⌥⌘- 缩小（保持当前比例）"
          }
        }
      }
    },
    "help.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How to Use"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用帮助"
          }
        }
      }
    },
    "hotkey.maximize" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximize Fit"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最大化适配"
          }
        }
      }
    },
    "hotkey.scaleDown" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zoom Out (-10%)"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "缩小 (-10%)"
          }
        }
      }
    },
    "hotkey.scaleUp" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zoom In (+10%)"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "放大 (+10%)"
          }
        }
      }
    },
    "onboarding.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to Dratio"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "欢迎使用 Dratio"
          }
        }
      }
    },
    "onboarding.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quickly resize any window to your preferred aspect ratio"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速将任意窗口调整为你想要的宽高比"
          }
        }
      }
    },
    "onboarding.feature.ratio.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preset Ratios"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "预设比例"
          }
        }
      }
    },
    "onboarding.feature.ratio.detail" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "16:9, 16:10, 4:3, 1:1, 3:4, 9:16 — one click to apply"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "16:9、16:10、4:3、1:1、3:4、9:16 — 一键应用"
          }
        }
      }
    },
    "onboarding.feature.hotkey.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Global Shortcuts"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "全局快捷键"
          }
        }
      }
    },
    "onboarding.feature.hotkey.detail" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use ⌥⌘1~6 to quickly switch ratios without opening the menu"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 ⌥⌘1~6 快速切换比例，无需打开菜单"
          }
        }
      }
    },
    "onboarding.feature.scale.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scale & Maximize"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "缩放与最大化"
          }
        }
      }
    },
    "onboarding.feature.scale.detail" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zoom in/out while keeping the ratio, or maximize to fit the screen"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持比例缩放窗口，或按比例最大化适配屏幕"
          }
        }
      }
    },
    "onboarding.permission.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accessibility Permission"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "辅助功能权限"
          }
        }
      }
    },
    "onboarding.permission.needed" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Required to resize windows of other apps"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要此权限来调整其他应用的窗口"
          }
        }
      }
    },
    "onboarding.permission.granted" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permission granted — you're all set!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已授权 — 一切就绪！"
          }
        }
      }
    },
    "onboarding.permission.grant" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grant Access"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "授予权限"
          }
        }
      }
    },
    "onboarding.permission.why" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dratio uses the Accessibility API to read and adjust window positions. Your data stays completely local."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dratio 通过辅助功能 API 读取和调整窗口位置，所有数据完全保留在本地。"
          }
        }
      }
    },
    "onboarding.done" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get Started"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
